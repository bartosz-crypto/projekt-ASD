<Window x:Class="AsdRcSlab.ReinforcementStubDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generuj zbrojenie — ASD RC SLAB"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel Margin="16">

        <Border Background="#1565C0" CornerRadius="4" Padding="10,8" Margin="0,0,0,14">
            <TextBlock x:Name="TxtHeader" Text="GENERUJ ZBROJENIE"
                       FontSize="13" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Info o siatce -->
        <Border Background="#E3F2FD" CornerRadius="3" Padding="10,8" Margin="0,0,0,12">
            <TextBlock x:Name="TxtMeshInfo" Text=""
                       FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Pole powierzchni -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Powierzchnia płyty (m²)"
                   VerticalAlignment="Center" FontSize="12"/>
            <TextBox Grid.Column="1" x:Name="TxtArea" Height="26"
                     Padding="4,2" FontSize="12" Text="0"/>
        </Grid>

        <!-- Wynik symulacji -->
        <Border x:Name="PanelResult" Background="#F1F8E9" CornerRadius="3"
                Padding="10,8" Margin="0,0,0,14" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="TxtResult" FontSize="12" TextWrapping="Wrap"
                           Foreground="#2E7D32"/>
            </StackPanel>
        </Border>

        <Border Background="#FFF8E1" CornerRadius="3" Padding="8,6" Margin="0,0,0,14">
            <TextBlock FontSize="11" Foreground="#F57F17" TextWrapping="Wrap"
                       Text="Pełne auto-rysowanie w ASD dostępne w Sprint 2. Ta wersja pokazuje symulację."/>
        </Border>

        <!-- Przyciski -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Symuluj" Width="80" Height="28" Margin="0,0,8,0"
                    Click="BtnSimulate_Click"
                    Background="#1565C0" Foreground="White" BorderThickness="0"/>
            <Button Content="Zamknij" Width="80" Height="28"
                    Click="BtnClose_Click"
                    Background="#757575" Foreground="White" BorderThickness="0"/>
        </StackPanel>

    </StackPanel>
</Window>
