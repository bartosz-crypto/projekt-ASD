<Window x:Class="AsdRcSlab.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy Projekt — ASD RC SLAB"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Naglowek -->
        <Border Background="#1565C0" CornerRadius="4" Padding="10,8" Margin="0,0,0,14">
            <TextBlock Text="NOWY PROJEKT" FontSize="14" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Grid z polami -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Nazwa projektu *"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtProjectName"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Klient"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtClientName"/>

            <Label Grid.Row="2" Grid.Column="0" Content="DRW Number *"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtDRWNumber"/>

            <Label Grid.Row="3" Grid.Column="0" Content="Rewizja"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtRevision" Text="P01"/>

            <Label Grid.Row="4" Grid.Column="0" Content="Grubosc plyty (mm)"/>
            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbSlab"
                      SelectionChanged="CmbSlab_SelectionChanged">
                <ComboBoxItem Content="225"/>
                <ComboBoxItem Content="300" IsSelected="True"/>
                <ComboBoxItem Content="375"/>
                <ComboBoxItem Content="450"/>
                <ComboBoxItem Content="525"/>
                <ComboBoxItem Content="600"/>
                <ComboBoxItem Content="675"/>
                <ComboBoxItem Content="750"/>
                <ComboBoxItem Content="825"/>
                <ComboBoxItem Content="900"/>
                <ComboBoxItem Content="975"/>
                <ComboBoxItem Content="1050"/>
                <ComboBoxItem Content="1125"/>
                <ComboBoxItem Content="1200"/>
            </ComboBox>

            <Label Grid.Row="5" Grid.Column="0" Content="fck (MPa)"/>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtFck"
                     Text="28" IsReadOnly="True" Background="#EEEEEE"/>

            <Label Grid.Row="6" Grid.Column="0" Content="k_spring (kN/m)"/>
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtKSpring"
                     Text="212333" IsReadOnly="True" Background="#EEEEEE"/>

            <Label Grid.Row="7" Grid.Column="0" Content="Hystool Code"/>
            <TextBox Grid.Row="7" Grid.Column="1" x:Name="TxtHystool"
                     Text="DK165" IsReadOnly="True" Background="#EEEEEE"/>

            <Label Grid.Row="8" Grid.Column="0" Content="Data projektu"/>
            <TextBox Grid.Row="8" Grid.Column="1" x:Name="TxtDate"/>
        </Grid>

        <!-- Blad walidacji -->
        <TextBlock x:Name="TxtError" Foreground="Red" FontSize="11"
                   Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Przyciski -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="BtnCancel" Content="Anuluj" Width="80" Height="28"
                    Margin="0,0,8,0" Click="BtnCancel_Click"
                    Background="#AAAAAA" Foreground="White" BorderThickness="0"/>
            <Button x:Name="BtnOK" Content="Zapisz projekt" Width="110" Height="28"
                    Click="BtnOK_Click"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold"/>
        </StackPanel>

    </StackPanel>
</Window>
