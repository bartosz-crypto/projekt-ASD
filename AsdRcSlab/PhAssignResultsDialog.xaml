<Window x:Class="AsdRcSlab.PhAssignResultsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign PH — Wyniki"
        Width="780" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565C0" CornerRadius="4"
                Padding="10,8" Margin="0,0,0,10">
            <TextBlock Text="ASSIGN PH — WYNIKI" FontSize="13" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Statystyki -->
        <Border Grid.Row="1" Background="#E3F2FD" CornerRadius="3"
                Padding="8,5" Margin="0,0,0,10">
            <TextBlock x:Name="TxtStats" FontSize="12" Foreground="#1565C0"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Tabela -->
        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False"
                  IsReadOnly="True" RowHeaderWidth="0"
                  BorderBrush="#CCCCCC" BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FAFAFA"
                  FontSize="11">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Pile ID"   Binding="{Binding PileId}"       Width="70"/>
                <DataGridTextColumn Header="Util %"    Binding="{Binding UtilPctStr}"   Width="60"/>
                <DataGridTextColumn Header="Location"  Binding="{Binding LocationType}" Width="80"/>
                <DataGridTextColumn Header="PH Action" Binding="{Binding PhAction}"     Width="75"/>
                <DataGridTextColumn Header="Tytuł detalu" Binding="{Binding DetailTitle}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PhAction}" Value="PH1">
                            <Setter Property="Background" Value="#E2EFDA"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PhAction}" Value="PH3-RE">
                            <Setter Property="Background" Value="#F3E5F5"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PhAction}" Value="PH7">
                            <Setter Property="Background" Value="#FCE4EC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PhAction}" Value="PH8">
                            <Setter Property="Background" Value="#FCE4EC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PhAction}" Value="PH9">
                            <Setter Property="Background" Value="#FCE4EC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PhAction}" Value="EXCEED">
                            <Setter Property="Background" Value="#B71C1C"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Przyciski -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Eksportuj do Excel" Width="130" Height="28" Margin="0,0,8,0"
                    Click="BtnExport_Click"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"/>
            <Button Content="Kopiuj tytuły" Width="100" Height="28" Margin="0,0,8,0"
                    Click="BtnCopyTitles_Click"
                    Background="#1565C0" Foreground="White" BorderThickness="0"/>
            <Button Content="Zamknij" Width="80" Height="28"
                    Click="BtnClose_Click"
                    Background="#757575" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
