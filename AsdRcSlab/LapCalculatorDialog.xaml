<Window x:Class="AsdRcSlab.LapCalculatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zakłady Auto — Note 16"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel Margin="16">

        <Border Background="#1565C0" CornerRadius="4" Padding="10,8" Margin="0,0,0,14">
            <TextBlock Text="KALKULATOR ZAKŁADÓW — NOTE 16"
                       FontSize="13" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Długość pola (m)"
                   VerticalAlignment="Center" FontSize="12"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtSpan"
                     Height="26" Padding="4,2" FontSize="12" Text="5.0"
                     TextChanged="Input_Changed"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Średnica pręta"
                   VerticalAlignment="Center" FontSize="12"/>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CmbDia"
                      Height="26" FontSize="12"
                      SelectionChanged="Input_Changed">
                <ComboBoxItem Content="H10" IsSelected="True"/>
                <ComboBoxItem Content="H12"/>
                <ComboBoxItem Content="H16"/>
            </ComboBox>
        </Grid>

        <!-- Wyniki -->
        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="0,0,0,10">
            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Długość zakładu l₀"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtL0"
                           VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                           Foreground="#1565C0" HorizontalAlignment="Right"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Pozycja zakładu od podpory"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtPos"
                           VerticalAlignment="Center" FontSize="12"
                           HorizontalAlignment="Right"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Stagger min (T vs B)"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtStagger"
                           VerticalAlignment="Center" FontSize="12"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Ostrzezenie -->
        <Border x:Name="PanelWarn" Background="#FFF8E1" CornerRadius="3"
                Padding="8,6" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock x:Name="TxtWarn" FontSize="11" Foreground="#F57F17"
                       TextWrapping="Wrap"/>
        </Border>

        <Button Content="Zamknij" Width="80" Height="28" HorizontalAlignment="Right"
                Click="BtnClose_Click"
                Background="#757575" Foreground="White" BorderThickness="0"/>
    </StackPanel>
</Window>
