<Window x:Class="AsdRcSlab.BmmResultsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Oznacz Pręty — Wyniki walidacji BBS"
        Width="520" Height="380"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565C0" CornerRadius="4"
                Padding="10,8" Margin="0,0,0,12">
            <TextBlock Text="BMM — WALIDACJA BBS" FontSize="13" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Podsumowanie -->
        <Border Grid.Row="1" x:Name="SummaryBorder" CornerRadius="3"
                Padding="8,6" Margin="0,0,0,10">
            <TextBlock x:Name="TxtSummary" FontSize="12" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Lista wyników -->
        <ListBox Grid.Row="2" x:Name="LstResults" Margin="0,0,0,10"
                 BorderBrush="#CCCCCC" BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2" Padding="8,6" CornerRadius="3"
                            Background="{Binding Background}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="12">
                                <Run Text="{Binding RuleId}"/>
                                <Run Text=" — "/>
                                <Run Text="{Binding Status}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Details}" FontSize="11"
                                       TextWrapping="Wrap" Foreground="#444444"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Przyciski -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Kopiuj raport" Width="100" Height="28" Margin="0,0,8,0"
                    Click="BtnCopy_Click"
                    Background="#1565C0" Foreground="White" BorderThickness="0"/>
            <Button Content="Zamknij" Width="80" Height="28"
                    Click="BtnClose_Click"
                    Background="#757575" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
