<Window x:Class="AsdRcSlab.SheetPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz arkusz" Height="280" Width="360"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Dostępne arkusze:" Margin="0,0,0,6"
                   FontWeight="SemiBold"/>

        <ListBox x:Name="LstSheets" Grid.Row="1" Margin="0,0,0,10"
                 MouseDoubleClick="LstSheets_DoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0"
                    Click="BtnOk_Click" IsDefault="True"/>
            <Button Content="Anuluj" Width="80" Height="28"
                    Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
